{
  "manifest_version": 3,
  "name": "Daem Plus",
  "version": "1.1",
  "description": "إضافة لتلوين البلاغات في منصة داعم بناءً على الحالة والوقت والمزامنة.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://tickets-daem.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://daem.momah.gov.sa/*"],
      "js": ["content.js"],
      "css": ["highlighter.css"],
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  }
}
